# Auto-generated by Copier for tenant: {{ tenant_slug }}
trigger:
  branches:
    include:
      - main

stages:
  - stage: Plan
    jobs:
      - job: TerraformPlan
        steps:
          - script: terraform init && terraform plan -out=tfplan
            displayName: 'terraform plan for {{ tenant_slug }}'
          - publish: tfplan
            artifact: tfplan-{{ tenant_slug }}

  - stage: Apply
    dependsOn: Plan
    jobs:
      - deployment: TerraformApply
        environment: 'app-gateway-{{ tenant_slug }}-approval'   # manual approval gate lives here
        strategy:
          runOnce:
            deploy:
              steps:
                - script: terraform apply tfplan
                  displayName: 'terraform apply for {{ tenant_slug }} (requires human approval)'
