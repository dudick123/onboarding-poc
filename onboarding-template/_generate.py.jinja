#!/usr/bin/env python3
"""
Post-generation scaffold for {{ tenant_slug }}'s per-app discrete repos.
Auto-generated by Copier as a _task — creates per-app directory trees for
build-repo, config-repo, and argocd-app under apps/{name}/, then self-deletes.
Existing files are never overwritten so hand-edits survive `copier update`.
"""
import os

# Tenant-level variables baked in by Copier at generation time
TENANT_SLUG = "{{ tenant_slug }}"
ADO_ORG = "{{ ado_org_name }}"
ADO_PROJECT = "{{ ado_project }}"
RESOURCE_TIER = "{{ resource_tier }}"
ENVIRONMENTS = {{ environments | tojson }}
ARGOCD_REVISION = "{{ argocd_target_revision }}"
KEY_VAULT_NAME = "{{ key_vault_name }}"

APPS = {{ apps | tojson(indent=2) }}

TIER_SPECS = {
    "small":  {"cpu_req": "100m",  "mem_req": "256Mi", "cpu_lim": "250m", "mem_lim": "512Mi", "replicas": 1},
    "medium": {"cpu_req": "250m",  "mem_req": "512Mi", "cpu_lim": "500m", "mem_lim": "1Gi",   "replicas": 2},
    "large":  {"cpu_req": "500m",  "mem_req": "1Gi",   "cpu_lim": "1",    "mem_lim": "2Gi",   "replicas": 3},
}
PROD_REPLICAS = {"small": 1, "medium": 2, "large": 3}

# Dockerfile templates use %(tenant)s substitution to avoid conflicts with
# Copier's Jinja2 rendering (curly-brace syntax would be consumed at render time).
DOCKERFILES = {
    "angular": """\
# Auto-generated by Copier for %(tenant)s — Angular SPA
# Multi-stage: build with Node, serve with nginx.
FROM node:20-alpine AS build
WORKDIR /app
COPY . .
RUN npm ci && npm run build --configuration=production

FROM nginx:alpine
COPY --from=build /app/dist/ /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
""",
    "react": """\
# Auto-generated by Copier for %(tenant)s — React SPA
# Multi-stage: build with Node, serve with nginx.
FROM node:20-alpine AS build
WORKDIR /app
COPY . .
RUN npm ci && npm run build

FROM nginx:alpine
COPY --from=build /app/build/ /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
""",
    "springboot": """\
# Auto-generated by Copier for %(tenant)s — Spring Boot API
# Multi-stage: build fat-jar with Maven wrapper, run with JRE.
FROM eclipse-temurin:21-jdk-alpine AS build
WORKDIR /build
COPY . .
RUN ./mvnw package -DskipTests

FROM eclipse-temurin:21-jre-alpine
WORKDIR /app
COPY --from=build /build/target/*.jar app.jar
EXPOSE 8080
ENTRYPOINT ["java", "-jar", "app.jar"]
""",
    "go": """\
# Auto-generated by Copier for %(tenant)s — Go API
# Multi-stage: compile with Go toolchain, run on minimal Alpine.
FROM golang:1.22-alpine AS build
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o app .

FROM alpine:3.19
WORKDIR /app
COPY --from=build /build/app .
EXPOSE 8080
ENTRYPOINT ["./app"]
""",
    "python": """\
# Auto-generated by Copier for %(tenant)s — Python API
# Installs dependencies from requirements.txt, runs with uvicorn.
FROM python:3.12-slim
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY . .
EXPOSE 8080
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8080"]
""",
    "dotnet": """\
# Auto-generated by Copier for %(tenant)s — .NET Core API
# Multi-stage: build with SDK image, run on ASP.NET runtime image.
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /build
COPY *.csproj .
RUN dotnet restore
COPY . .
RUN dotnet publish -c Release -o /app

FROM mcr.microsoft.com/dotnet/aspnet:8.0
WORKDIR /app
COPY --from=build /app .
EXPOSE 8080
ENTRYPOINT ["dotnet", "app.dll"]
""",
}


def write_if_new(path, content):
    if os.path.exists(path):
        print(f"  skipped  {path}  (exists — not overwriting)")
        return
    parent = os.path.dirname(path)
    if parent:
        os.makedirs(parent, exist_ok=True)
    with open(path, "w") as fh:
        fh.write(content)
    print(f"  created  {path}")


for app in APPS:
    name = app["name"]
    app_type = app["type"]
    image = app["container_image"]
    specs = TIER_SPECS[RESOURCE_TIER]

    print(f"\n[{name}] scaffolding per-app repos...")

    # ------------------------------------------------------------------
    # build-repo  →  ADO repo: {name}
    # ------------------------------------------------------------------
    build_root = f"apps/{name}/build-repo"
    write_if_new(f"{build_root}/src/.gitkeep", "")
    dockerfile = (DOCKERFILES.get(app_type) or DOCKERFILES["springboot"]) % {"tenant": TENANT_SLUG}
    write_if_new(f"{build_root}/Dockerfile", dockerfile)
    write_if_new(f"{build_root}/azure-pipelines.yml", f"""\
# Auto-generated by Copier for {TENANT_SLUG} — {name} ({app_type})
trigger:
  branches:
    include:
      - main

stages:
  - stage: BuildAndPush
    displayName: 'Build and push {name}'
    jobs:
      - job: DockerBuildPush
        steps:
          - task: Docker@2
            inputs:
              command: buildAndPush
              repository: {image}
              dockerfile: Dockerfile
              buildContext: .
              tags: |
                $(Build.BuildId)
            displayName: 'Build and push {name} ({app_type})'
""")

    # ------------------------------------------------------------------
    # config-repo  →  ADO repo: {name}-k8s-manifests
    # ------------------------------------------------------------------
    config_root = f"apps/{name}/config-repo"
    base_dir = f"{config_root}/{name}/base"

    write_if_new(f"{base_dir}/kustomization.yaml", f"""\
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

metadata:
  name: {name}-base

commonLabels:
  app.kubernetes.io/part-of: {TENANT_SLUG}
  app.kubernetes.io/name: {name}
  platform.io/tenant: {TENANT_SLUG}
  platform.io/tier: {RESOURCE_TIER}

resources:
  - deployment.yaml
  - service.yaml
  - external-secret.yaml
""")
    write_if_new(f"{base_dir}/deployment.yaml", f"""\
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {name}
  namespace: {TENANT_SLUG}
  labels:
    app: {name}
    platform.io/tier: {RESOURCE_TIER}
spec:
  replicas: {specs["replicas"]}
  selector:
    matchLabels:
      app: {name}
  template:
    metadata:
      labels:
        app: {name}
    spec:
      containers:
        - name: {name}
          image: {image}:latest
          resources:
            requests:
              cpu: {specs["cpu_req"]}
              memory: {specs["mem_req"]}
            limits:
              cpu: {specs["cpu_lim"]}
              memory: {specs["mem_lim"]}
          envFrom:
            - secretRef:
                name: {TENANT_SLUG}-secrets
""")
    write_if_new(f"{base_dir}/service.yaml", f"""\
apiVersion: v1
kind: Service
metadata:
  name: {name}
  namespace: {TENANT_SLUG}
  labels:
    app: {name}
spec:
  selector:
    app: {name}
  ports:
    - port: 8080
      targetPort: 8080
""")
    write_if_new(f"{base_dir}/external-secret.yaml", f"""\
apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: {TENANT_SLUG}-secrets
  namespace: {TENANT_SLUG}
spec:
  refreshInterval: 1h
  secretStoreRef:
    name: {KEY_VAULT_NAME}-store
    kind: SecretStore
  target:
    name: {TENANT_SLUG}-secrets
  dataFrom:
    - extract:
        key: {TENANT_SLUG}
""")

    for env in ENVIRONMENTS:
        prod_replicas = PROD_REPLICAS[RESOURCE_TIER]
        replica_count = prod_replicas if env == "prod" else 1
        overlay_dir = f"{config_root}/{name}/overlays/{env}"
        write_if_new(f"{overlay_dir}/kustomization.yaml", f"""\
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: {TENANT_SLUG}-{env}

resources:
  - ../../base

namePrefix: {env}-

replicas:
  - name: {name}
    count: {replica_count}

images:
  - name: {image}
    newTag: {env}
""")

    overlay_build_cmds = "\n".join(
        f"              kustomize build {name}/overlays/{env} > /tmp/{env}.yaml"
        for env in ENVIRONMENTS
    )
    write_if_new(f"{config_root}/azure-pipelines.yml", f"""\
# Auto-generated by Copier for {TENANT_SLUG} — {name} config repo
trigger:
  branches:
    include:
      - main

stages:
  - stage: ValidateManifests
    jobs:
      - job: KustomizeBuild
        steps:
          - script: |
{overlay_build_cmds}
            displayName: 'kustomize build all overlays'
""")

    # ------------------------------------------------------------------
    # argocd-app  →  ADO repo: {name}-argocd
    # ------------------------------------------------------------------
    argocd_root = f"apps/{name}/argocd-app"
    write_if_new(f"{argocd_root}/application.yaml", f"""\
# Auto-generated by Copier for {TENANT_SLUG} — {name}
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: {TENANT_SLUG}-{name}
  namespace: argocd
spec:
  project: {TENANT_SLUG}
  source:
    repoURL: https://dev.azure.com/{ADO_ORG}/{ADO_PROJECT}/_git/{name}-k8s-manifests
    targetRevision: {ARGOCD_REVISION}
    path: {name}/overlays/prod
  destination:
    server: https://kubernetes.default.svc
    namespace: {TENANT_SLUG}-prod
  syncPolicy:
    automated: null   # manual sync only — change control gate lives in the pipeline below
""")
    write_if_new(f"{argocd_root}/azure-pipelines.yml", f"""\
# Auto-generated by Copier for {TENANT_SLUG} — {name} ArgoCD sync
trigger: none   # manually triggered only — this IS the change-control gate

stages:
  - stage: Sync
    jobs:
      - deployment: ArgoCDSync
        environment: 'argocd-sync-{TENANT_SLUG}-{name}-approval'
        strategy:
          runOnce:
            deploy:
              steps:
                - script: argocd app sync {TENANT_SLUG}-{name} --prune
                  displayName: 'ArgoCD sync for {TENANT_SLUG}/{name} (requires human approval)'
""")

print("\nDone. Per-app repo scaffolding complete.")
