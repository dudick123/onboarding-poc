#!/usr/bin/env python3
"""
Post-generation scaffold for {{ tenant_slug }}'s per-app discrete repos.
Auto-generated by Copier as a _task — creates per-app directory trees for
build-repo, config-repo, and argocd-app under apps/{name}/, then self-deletes.
Existing files are never overwritten so hand-edits survive `copier update`.
"""
import os
import shutil

# Tenant-level variables baked in by Copier at generation time
TENANT_SLUG = "{{ tenant_slug }}"
ADO_ORG = "{{ ado_org_name }}"
ADO_PROJECT = "{{ ado_project }}"
RESOURCE_TIER = "{{ resource_tier }}"
ENVIRONMENTS = {{ environments | tojson }}
ARGOCD_REVISION = "{{ argocd_target_revision }}"
KEY_VAULT_NAME = "{{ key_vault_name }}"

APPS = {{ apps | tojson(indent=2) }}

TIER_SPECS = {
    "small":  {"cpu_req": "100m",  "mem_req": "256Mi", "cpu_lim": "250m", "mem_lim": "512Mi", "replicas": 1},
    "medium": {"cpu_req": "250m",  "mem_req": "512Mi", "cpu_lim": "500m", "mem_lim": "1Gi",   "replicas": 2},
    "large":  {"cpu_req": "500m",  "mem_req": "1Gi",   "cpu_lim": "1",    "mem_lim": "2Gi",   "replicas": 3},
}
PROD_REPLICAS = {"small": 1, "medium": 2, "large": 3}
MAX_REPLICAS  = {"small": 3, "medium": 6, "large": 9}


def write_if_new(path, content):
    if os.path.exists(path):
        print(f"  skipped  {path}  (exists — not overwriting)")
        return
    parent = os.path.dirname(path)
    if parent:
        os.makedirs(parent, exist_ok=True)
    with open(path, "w") as fh:
        fh.write(content)
    print(f"  created  {path}")


def copy_exemplar_file(src_path, dst_path):
    """Copy a file from the exemplar staging area; preserve executable bit."""
    if os.path.exists(dst_path):
        print(f"  skipped  {dst_path}  (exists — not overwriting)")
        return
    parent = os.path.dirname(dst_path)
    if parent:
        os.makedirs(parent, exist_ok=True)
    with open(src_path, "rb") as src:
        data = src.read()
    with open(dst_path, "wb") as dst:
        dst.write(data)
    if os.stat(src_path).st_mode & 0o111:  # preserve executable bit (e.g. mvnw)
        os.chmod(dst_path, os.stat(dst_path).st_mode | 0o755)
    print(f"  created  {dst_path}")


def _make_config_stage_ref(env, name, image, tenant_slug, environments):
    """Return a stages/promote.yml@pipelineTemplates template reference for one environment."""
    eu = env.upper()
    idx = environments.index(env)
    is_first = idx == 0
    prev_eu = environments[idx - 1].upper() if not is_first else None

    lines = [
        f"  - template: stages/promote.yml@pipelineTemplates",
        f"    parameters:",
        f"      env: {env}",
        f"      appName: '{name}'",
        f"      tenantSlug: '{tenant_slug}'",
        f"      containerImage: '{image}'",
        f"      isFirstEnv: {'true' if is_first else 'false'}",
        f"      dependsOn: {f'[Promote{prev_eu}]' if prev_eu else '[]'}",
    ]
    if not is_first:
        lines += [
            f"      argocdServer: $(ARGOCD_SERVER_{eu})",
            f"      argocdToken: $(ARGOCD_TOKEN_{eu})",
        ]
    return "\n".join(lines)


def _make_argocd_stage_ref(env, name, tenant_slug, environments):
    """Return a stages/argocd-sync.yml@pipelineTemplates template reference for one environment."""
    eu = env.upper()
    idx = environments.index(env)
    prev_eu = environments[idx - 1].upper() if idx > 0 else None

    lines = [
        f"  - template: stages/argocd-sync.yml@pipelineTemplates",
        f"    parameters:",
        f"      env: {env}",
        f"      appName: '{name}'",
        f"      tenantSlug: '{tenant_slug}'",
        f"      argocdAppName: '{tenant_slug}-{name}'",
        f"      argocdServer: $(ARGOCD_SERVER_{eu})",
        f"      argocdToken: $(ARGOCD_TOKEN_{eu})",
        f"      dependsOn: {f'[Sync{prev_eu}]' if prev_eu else '[]'}",
    ]
    return "\n".join(lines)


for app in APPS:
    name = app["name"]
    app_type = app["type"]
    image = app["container_image"]
    specs = TIER_SPECS[RESOURCE_TIER]
    max_replicas = MAX_REPLICAS[RESOURCE_TIER]

    print(f"\n[{name}] scaffolding per-app repos...")

    # ------------------------------------------------------------------
    # build-repo  →  ADO repo: {name}
    # Copy the full exemplar-apps/app-{type}/ directory into build-repo.
    # The exemplar contains a working Dockerfile, type-specific CI pipeline,
    # source code, and tests — all skipped if already present (copier update safe).
    # ------------------------------------------------------------------
    build_root = f"apps/{name}/build-repo"
    exemplar_dir = f"exemplar-apps/app-{app_type}"

    if os.path.isdir(exemplar_dir):
        for dirpath, _dirs, filenames in os.walk(exemplar_dir):
            for filename in filenames:
                if filename == ".gitkeep":
                    continue
                src_path = os.path.join(dirpath, filename)
                rel_path = os.path.relpath(src_path, exemplar_dir)
                dst_path = os.path.join(build_root, rel_path)
                copy_exemplar_file(src_path, dst_path)
    else:
        print(f"  WARNING: no exemplar found at '{exemplar_dir}' — build-repo will be empty")

    # Copy shared CI build skills into build-repo .agents/skills/
    build_skills_src = "exemplar-apps/.ci-build-skills"
    if os.path.isdir(build_skills_src):
        for dirpath, _dirs, filenames in os.walk(build_skills_src):
            for filename in filenames:
                src_path = os.path.join(dirpath, filename)
                rel_path = os.path.relpath(src_path, build_skills_src)
                dst_path = os.path.join(build_root, ".agents", "skills", rel_path)
                copy_exemplar_file(src_path, dst_path)

    # Copy shared CI build docs (ARCHITECTURE, EXAMPLES, AGENT-SKILLS) into build-repo root.
    # Type-specific README.md and QUICK-START.md are already present from the exemplar dir above
    # and will be skipped by copy_exemplar_file if they exist, so the exemplar versions win.
    build_docs_src = "exemplar-apps/.ci-build-docs"
    if os.path.isdir(build_docs_src):
        for dirpath, _dirs, filenames in os.walk(build_docs_src):
            for filename in filenames:
                src_path = os.path.join(dirpath, filename)
                rel_path = os.path.relpath(src_path, build_docs_src)
                dst_path = os.path.join(build_root, rel_path)
                copy_exemplar_file(src_path, dst_path)

    # ------------------------------------------------------------------
    # config-repo  →  ADO repo: {name}-k8s-manifests
    # ------------------------------------------------------------------
    config_root = f"apps/{name}/config-repo"
    base_dir = f"{config_root}/{name}/base"

    write_if_new(f"{base_dir}/kustomization.yaml", f"""\
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

metadata:
  name: {name}-base

commonLabels:
  app.kubernetes.io/part-of: {TENANT_SLUG}
  app.kubernetes.io/name: {name}
  platform.io/tenant: {TENANT_SLUG}
  platform.io/tier: {RESOURCE_TIER}

resources:
  - serviceaccount.yaml
  - deployment.yaml
  - service.yaml
  - hpa.yaml
  - vpa.yaml
  - pdb.yaml
  - external-secret.yaml
""")

    write_if_new(f"{base_dir}/serviceaccount.yaml", f"""\
apiVersion: v1
kind: ServiceAccount
metadata:
  name: {name}
  namespace: {TENANT_SLUG}
  labels:
    app.kubernetes.io/name: {name}
    platform.io/tenant: {TENANT_SLUG}
""")

    write_if_new(f"{base_dir}/deployment.yaml", f"""\
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {name}
  namespace: {TENANT_SLUG}
  labels:
    app: {name}
    platform.io/tier: {RESOURCE_TIER}
spec:
  replicas: {specs["replicas"]}
  selector:
    matchLabels:
      app: {name}
  template:
    metadata:
      labels:
        app: {name}
    spec:
      serviceAccountName: {name}
      containers:
        - name: {name}
          image: {image}:latest
          resources:
            requests:
              cpu: {specs["cpu_req"]}
              memory: {specs["mem_req"]}
            limits:
              cpu: {specs["cpu_lim"]}
              memory: {specs["mem_lim"]}
          envFrom:
            - secretRef:
                name: {TENANT_SLUG}-secrets
""")

    write_if_new(f"{base_dir}/service.yaml", f"""\
apiVersion: v1
kind: Service
metadata:
  name: {name}
  namespace: {TENANT_SLUG}
  labels:
    app: {name}
spec:
  selector:
    app: {name}
  ports:
    - port: 8080
      targetPort: 8080
""")

    write_if_new(f"{base_dir}/hpa.yaml", f"""\
apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
  name: {name}
  namespace: {TENANT_SLUG}
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: {name}
  minReplicas: {specs["replicas"]}
  maxReplicas: {max_replicas}
  metrics:
    - type: Resource
      resource:
        name: cpu
        target:
          type: Utilization
          averageUtilization: 70
    - type: Resource
      resource:
        name: memory
        target:
          type: Utilization
          averageUtilization: 80
""")

    write_if_new(f"{base_dir}/vpa.yaml", f"""\
apiVersion: autoscaling.k8s.io/v1
kind: VerticalPodAutoscaler
metadata:
  name: {name}
  namespace: {TENANT_SLUG}
spec:
  targetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: {name}
  updatePolicy:
    updateMode: "Off"
  resourcePolicy:
    containerPolicies:
      - containerName: {name}
        minAllowed:
          cpu: {specs["cpu_req"]}
          memory: {specs["mem_req"]}
        maxAllowed:
          cpu: {specs["cpu_lim"]}
          memory: {specs["mem_lim"]}
""")

    write_if_new(f"{base_dir}/pdb.yaml", f"""\
apiVersion: policy/v1
kind: PodDisruptionBudget
metadata:
  name: {name}
  namespace: {TENANT_SLUG}
spec:
  maxUnavailable: 1
  selector:
    matchLabels:
      app: {name}
""")

    write_if_new(f"{base_dir}/external-secret.yaml", f"""\
apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: {TENANT_SLUG}-secrets
  namespace: {TENANT_SLUG}
spec:
  refreshInterval: 1h
  secretStoreRef:
    name: {KEY_VAULT_NAME}-store
    kind: SecretStore
  target:
    name: {TENANT_SLUG}-secrets
  dataFrom:
    - extract:
        key: {TENANT_SLUG}
""")

    # Overlays — one per environment
    for env in ENVIRONMENTS:
        prod_replicas = PROD_REPLICAS[RESOURCE_TIER]
        replica_count = prod_replicas if env == "prod" else 1
        overlay_dir = f"{config_root}/{name}/overlays/{env}"

        write_if_new(f"{overlay_dir}/kustomization.yaml", f"""\
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: {TENANT_SLUG}-{env}

resources:
  - ../../base

namePrefix: {env}-

replicas:
  - name: {name}
    count: {replica_count}

images:
  - name: {image}
    newTag: pending

patches:
  - path: annotation-patch.yaml
""")

        # Placeholder annotations; the config promotion pipeline overwrites these on each run.
        write_if_new(f"{overlay_dir}/annotation-patch.yaml", f"""\
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {name}
  annotations:
    platform.io/image-sha: "pending"
    platform.io/image-tag: "pending"
    platform.io/promoted-at: "pending"
    platform.io/source-pipeline: "pending"
""")

    # Config-repo promotion pipeline
    # Uses stages/promote.yml@pipelineTemplates — one template call per environment.
    # Stage 1 (first env): no gate, ArgoCD auto-sync. Stage N: ADO environment gate + argocd sync.
    stage_refs = "\n\n".join(
        _make_config_stage_ref(env, name, image, TENANT_SLUG, ENVIRONMENTS)
        for env in ENVIRONMENTS
    )

    write_if_new(f"{config_root}/azure-pipelines.yml", (
        f"# Auto-generated by Copier for {TENANT_SLUG} — {name} config repo\n"
        f"# Triggered automatically when the {name} build pipeline completes on main.\n"
        f"# Requires variable group 'argocd-servers' with:\n"
        + "".join(
            f"#   ARGOCD_SERVER_{e.upper()}, ARGOCD_TOKEN_{e.upper()}\n"
            for e in ENVIRONMENTS
        )
        + "trigger: none\n"
        "\n"
        "resources:\n"
        "  pipelines:\n"
        "    - pipeline: BuildPipeline\n"
        f"      source: {name}\n"
        "      trigger:\n"
        "        branches:\n"
        "          include:\n"
        "            - main\n"
        "  repositories:\n"
        "    - repository: pipelineTemplates\n"
        "      type: git\n"
        "      name: platform-pipeline-templates\n"
        "      ref: main\n"
        "\n"
        "variables:\n"
        "  - group: argocd-servers\n"
        f"  - name: APP_NAME\n"
        f"    value: '{name}'\n"
        f"  - name: TENANT_SLUG\n"
        f"    value: '{TENANT_SLUG}'\n"
        "\n"
        "stages:\n"
        f"{stage_refs}\n"
    ))

    # Copy shared CI config skills into config-repo .agents/skills/
    config_skills_src = "exemplar-apps/.ci-config-skills"
    if os.path.isdir(config_skills_src):
        for dirpath, _dirs, filenames in os.walk(config_skills_src):
            for filename in filenames:
                src_path = os.path.join(dirpath, filename)
                rel_path = os.path.relpath(src_path, config_skills_src)
                dst_path = os.path.join(config_root, ".agents", "skills", rel_path)
                copy_exemplar_file(src_path, dst_path)

    # Copy shared CI config docs into config-repo root.
    config_docs_src = "exemplar-apps/.ci-config-docs"
    if os.path.isdir(config_docs_src):
        for dirpath, _dirs, filenames in os.walk(config_docs_src):
            for filename in filenames:
                src_path = os.path.join(dirpath, filename)
                rel_path = os.path.relpath(src_path, config_docs_src)
                dst_path = os.path.join(config_root, rel_path)
                copy_exemplar_file(src_path, dst_path)

    # ------------------------------------------------------------------
    # argocd-app  →  ADO repo: {name}-argocd
    # One ArgoCD Application CRD per environment, each targeting its own
    # dedicated control plane (different FQDN per env).
    # Apply each file to the corresponding ArgoCD control plane:
    #   kubectl apply -f {env}/application.yaml  (against that env's cluster)
    # ------------------------------------------------------------------
    argocd_root = f"apps/{name}/argocd-app"

    for i, env in enumerate(ENVIRONMENTS):
        is_first = i == 0
        if is_first:
            # First environment: automated sync enabled (ArgoCD watches the overlay).
            sync_policy = (
                "    automated:\n"
                "      prune: true\n"
                "      selfHeal: true\n"
            )
        else:
            # Subsequent environments: manual sync only — config promotion pipeline drives sync.
            sync_policy = (
                "    automated: null\n"
                "    # Sync is driven by the config promotion pipeline (azure-pipelines.yml).\n"
                "    # Do not enable automated here — the ADO environment gate is the change control.\n"
            )

        write_if_new(f"{argocd_root}/{env}/application.yaml", (
            f"# Auto-generated by Copier for {TENANT_SLUG} — {name} ({env.upper()})\n"
            f"# Apply to the {env.upper()} ArgoCD control plane (ARGOCD_SERVER_{env.upper()}).\n"
            "apiVersion: argoproj.io/v1alpha1\n"
            "kind: Application\n"
            "metadata:\n"
            f"  name: {TENANT_SLUG}-{name}\n"
            "  namespace: argocd\n"
            "spec:\n"
            f"  project: {TENANT_SLUG}\n"
            "  source:\n"
            f"    repoURL: https://dev.azure.com/{ADO_ORG}/{ADO_PROJECT}/_git/{name}-k8s-manifests\n"
            f"    targetRevision: {ARGOCD_REVISION}\n"
            f"    path: {name}/overlays/{env}\n"
            "  destination:\n"
            "    server: https://kubernetes.default.svc\n"
            f"    namespace: {TENANT_SLUG}-{env}\n"
            "  syncPolicy:\n"
            f"{sync_policy}"
        ))

    # Standalone ArgoCD sync pipeline — manual escape hatch if config pipeline is unavailable.
    # Uses stages/argocd-sync.yml@pipelineTemplates — one template call per environment.
    argocd_stage_refs = "\n\n".join(
        _make_argocd_stage_ref(env, name, TENANT_SLUG, ENVIRONMENTS)
        for env in ENVIRONMENTS
    )

    write_if_new(f"{argocd_root}/azure-pipelines.yml", (
        f"# Auto-generated by Copier for {TENANT_SLUG} — {name} ArgoCD sync\n"
        "# MANUAL ESCAPE HATCH — the config-repo promotion pipeline is the primary sync driver.\n"
        "# Use this pipeline only when the normal promotion flow is unavailable.\n"
        "trigger: none\n"
        "\n"
        "resources:\n"
        "  repositories:\n"
        "    - repository: pipelineTemplates\n"
        "      type: git\n"
        "      name: platform-pipeline-templates\n"
        "      ref: main\n"
        "\n"
        "variables:\n"
        "  - group: argocd-servers\n"
        "\n"
        "stages:\n"
        f"{argocd_stage_refs}\n"
    ))

# Clean up the exemplar staging area — Copier copied it here for use by this
# script but it should not appear in the final tenant output.
shutil.rmtree("exemplar-apps", ignore_errors=True)

print("\nDone. Per-app repo scaffolding complete.")
