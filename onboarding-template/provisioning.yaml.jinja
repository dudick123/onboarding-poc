# Auto-generated by Copier for tenant: {{ tenant_slug }}
# This file is the input to the ADO provisioning step (repo creation,
# pipeline registration, environment/approval setup) that runs AFTER
# copier copy. Each app in the tenant gets three discrete ADO repos:
#   {name}               — build repo
#   {name}-k8s-manifests — Kustomize config repo
#   {name}-argocd        — ArgoCD Application + sync pipeline

tenant_slug: {{ tenant_slug }}
ado_project: {{ ado_project }}

components:
{% if include_app_gateway %}
  app_gateway:
    source_dir: app-gateway
    repo_name: {{ tenant_slug }}-app-gateway
    pipeline_yaml_path: azure-pipelines.yml
    pipeline_name: {{ tenant_slug }}-app-gateway-plan-apply
    environments:
      - name: app-gateway-{{ tenant_slug }}-approval
        requires_approval: true
{% endif %}
{% for app in apps %}
  {{ app.name | replace('-', '_') }}_build:
    source_dir: apps/{{ app.name }}/build-repo
    repo_name: {{ app.name }}
    pipeline_yaml_path: azure-pipelines.yml
    pipeline_name: {{ app.name }}-build-push
    environments: []
  {{ app.name | replace('-', '_') }}_config:
    source_dir: apps/{{ app.name }}/config-repo
    repo_name: {{ app.name }}-k8s-manifests
    pipeline_yaml_path: azure-pipelines.yml
    pipeline_name: {{ app.name }}-kustomize-build
    environments: []
  {{ app.name | replace('-', '_') }}_argocd:
    source_dir: apps/{{ app.name }}/argocd-app
    repo_name: {{ app.name }}-argocd
    pipeline_yaml_path: azure-pipelines.yml
    pipeline_name: {{ app.name }}-argocd-sync
    environments:
      - name: argocd-sync-{{ tenant_slug }}-{{ app.name }}-approval
        requires_approval: true
{% endfor %}

# Push order: build and config repos before argocd (which references config repo
# remote URL); app_gateway is independent.
push_order:
{% if include_app_gateway %}
  - app_gateway
{% endif %}
{% for app in apps %}
  - {{ app.name | replace('-', '_') }}_build
  - {{ app.name | replace('-', '_') }}_config
  - {{ app.name | replace('-', '_') }}_argocd
{% endfor %}
