# Auto-generated by Copier for tenant: {{ tenant_slug }}
# This file is the input to the ADO provisioning step (repo creation,
# pipeline registration, environment/approval setup) that runs AFTER
# copier copy. It is derived from the same answers that produced the
# rendered component directories above, so naming here is guaranteed
# to match the directory structure Copier just wrote.

tenant_slug: {{ tenant_slug }}
ado_project: {{ ado_project }}

components:
{% if include_app_gateway %}
  app_gateway:
    source_dir: app-gateway
    repo_name: {{ tenant_slug }}-app-gateway
    pipeline_yaml_path: azure-pipelines.yml
    pipeline_name: {{ tenant_slug }}-app-gateway-plan-apply
    environments:
      - name: app-gateway-{{ tenant_slug }}-approval
        requires_approval: true
{% endif %}
{% if include_build_repo %}
  build_repo:
    source_dir: build-repo
    repo_name: {{ tenant_slug }}-build
    pipeline_yaml_path: azure-pipelines.yml
    pipeline_name: {{ tenant_slug }}-build-push
    environments: []
{% endif %}
{% if include_config_repo %}
  config_repo:
    source_dir: config-repo
    repo_name: {{ tenant_slug }}-config
    pipeline_yaml_path: {{ tenant_slug }}/azure-pipelines.yml
    pipeline_name: {{ tenant_slug }}-kustomize-build
    environments: []
{% endif %}
{% if include_argocd_app %}
  argocd_app:
    source_dir: argocd-app
    repo_name: {{ tenant_slug }}-argocd
    pipeline_yaml_path: azure-pipelines.yml
    pipeline_name: {{ tenant_slug }}-argocd-sync
    environments:
      - name: argocd-sync-{{ tenant_slug }}-approval
        requires_approval: true
{% endif %}

# Push order matters when multiple components reference each other:
# build_repo and config_repo before argocd_app (which references config_repo's
# remote URL by convention); app_gateway is independent and can go anytime.
push_order:
{% if include_build_repo %}
  - build_repo
{% endif %}
{% if include_config_repo %}
  - config_repo
{% endif %}
{% if include_app_gateway %}
  - app_gateway
{% endif %}
{% if include_argocd_app %}
  - argocd_app
{% endif %}
