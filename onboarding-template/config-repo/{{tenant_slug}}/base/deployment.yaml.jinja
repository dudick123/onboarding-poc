{% set tier_specs = {
  "small":  {"cpu_req": "100m", "mem_req": "256Mi", "cpu_lim": "250m", "mem_lim": "512Mi", "replicas": 1},
  "medium": {"cpu_req": "250m", "mem_req": "512Mi", "cpu_lim": "500m", "mem_lim": "1Gi",   "replicas": 2},
  "large":  {"cpu_req": "500m", "mem_req": "1Gi",   "cpu_lim": "1",    "mem_lim": "2Gi",   "replicas": 3},
} %}
{% set specs = tier_specs[resource_tier] %}
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ tenant_slug }}
  namespace: {{ tenant_slug }}
  labels:
    app: {{ tenant_slug }}
    platform.io/tier: {{ resource_tier }}
spec:
  replicas: {{ specs.replicas }}
  selector:
    matchLabels:
      app: {{ tenant_slug }}
  template:
    metadata:
      labels:
        app: {{ tenant_slug }}
    spec:
      containers:
        - name: {{ tenant_slug }}
          image: {{ container_image }}:latest
          resources:
            requests:
              cpu: {{ specs.cpu_req }}
              memory: {{ specs.mem_req }}
            limits:
              cpu: {{ specs.cpu_lim }}
              memory: {{ specs.mem_lim }}
          envFrom:
            - secretRef:
                name: {{ tenant_slug }}-secrets
